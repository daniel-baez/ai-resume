{
  "name": "ai-resume",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run copy-pdf-worker && next dev",
    "build:original": "next build",
    "build": "npm test && npm run clean && npm run generate-assets && npm run build:original",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "prepare": "husky",
    "generate-pdfs": "npx tsx scripts/generate-pdfs.tsx",
    "generate-previews": "npx tsx scripts/generate-document-previews.tsx",
    "copy-pdf-worker": "cp node_modules/pdfjs-dist/build/pdf.worker.mjs public/pdf.worker.mjs",
    "generate-assets": "npm run generate-pdfs && npm run generate-previews && npm run copy-pdf-worker",
    "clean": "rm -rf public/pdfs/*.pdf public/pdfs/og public/certificates/og public/experience_letters/og",
    "test": "NODE_ENV=test tsx --test $(find tests/unit tests/integration -type f \\( -name '*.test.ts' -o -name '*.test.tsx' \\) | sort)",
    "test:unit": "NODE_ENV=test tsx --test $(find tests/unit -name '*.test.ts' | sort)",
    "test:integration": "NODE_ENV=test tsx --test $(find tests/integration -type f \\( -name '*.test.ts' -o -name '*.test.tsx' \\) | sort)",
    "test:watch": "NODE_ENV=test tsx --watch --test $(find tests/unit tests/integration -type f \\( -name '*.test.ts' -o -name '*.test.tsx' \\) | sort)"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --max-warnings 0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.4",
    "@react-pdf/renderer": "^4.1.6",
    "@vercel/analytics": "^1.5.0",
    "@vercel/edge": "^1.1.4",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.0.2",
    "gray-matter": "^4.0.3",
    "libphonenumber-js": "^1.11.17",
    "lucide-react": "^0.456.0",
    "next": "15.0.5",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.8.69",
    "react": "19.0.1",
    "react-dom": "19.0.1",
    "react-markdown": "^9.0.1",
    "react-phone-input-2": "^2.15.1",
    "resend": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "@types/next": "^9.0.0",
    "@types/node": "^20.17.47",
    "@types/pdfjs-dist": "^2.10.378",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/validator": "^13.12.2",
    "autoprefixer": "^10.0.1",
    "canvas": "^3.2.3",
    "eslint": "^8",
    "eslint-config-next": "15.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5"
  }
}
